{
  "name": "blog.igorcodes.dev",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "pnpm fonts:fetch && next build",
    "start": "next start",
    "fonts:fetch": "node app/_tools/fetch-fonts.mjs",
    "fonts:upload": "node app/_tools/upload-fonts.mjs",
    "new:post": "node app/_tools/new-post.mjs",
    "posts:validate": "tsx app/_tools/validate-posts.ts",
    "icons:generate": "node app/_tools/generate-icons.mjs",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rehype-pretty-code": "^0.14.3",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.3.1",
    "tailwind-merge": "^3.6.0",
    "unified": "^11.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/mdast": "4.0.4",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/unist": "3.0.3",
    "@vercel/blob": "^2.5.0",
    "lefthook": "^2.1.9",
    "mdast-util-mdx-jsx": "3.2.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
