# Copy to .env.local and fill in. All NEXT_PUBLIC_* vars are exposed to the
# browser (non-secret).

# Canonical site origin (no trailing slash). Falls back to the production URL.
NEXT_PUBLIC_SITE_URL="https://blog.igorcodes.dev"

# Umami analytics. Leave the website ID unset to disable analytics (e.g. local
# dev). When set, the script loads from the URL below.
NEXT_PUBLIC_UMAMI_WEBSITE_ID="0aa17cc2-4dda-408c-8211-b361b76dfa91"
NEXT_PUBLIC_UMAMI_SCRIPT_URL="https://cloud.umami.is/script.js"
